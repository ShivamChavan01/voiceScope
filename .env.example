# LLM Provider Configuration
# Options: openai, anthropic, gemini, ollama, mistral, groq
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Google Gemini
GOOGLE_API_KEY=your-google-api-key

# Groq (free, fast inference)
GROQ_API_KEY=gsk_your-groq-key

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# Mistral
MISTRAL_API_KEY=your-mistral-api-key

# Deepgram (STT)
DEEPGRAM_API_KEY=your-deepgram-key

# STT Provider (auto-detected from available API keys if unset)
# Options: deepgram, whisper, gemini
STT_PROVIDER=

# Authentication (REQUIRED — server returns 503 if not set)
VALID_API_KEYS=your-api-key-1,your-api-key-2

# CORS (comma-separated origins, leave empty to disable CORS)
CORS_ORIGINS=

# Rate Limiting
RATE_LIMIT_RPM=60

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# Data directory for local SQLite fallback
DATA_DIR=./data

# Server port
PORT=8000

# App
APP_ENV=development

# PostgreSQL (Supabase or self-hosted) — leave unset to use SQLite fallback
# DATABASE_URL=postgresql://user:password@host:5432/dbname
